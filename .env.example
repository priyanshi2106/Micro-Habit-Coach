# Backend — copy to backend/.env and adjust if needed.
# Defaults below match the docker-compose.yml dev database exactly.

DATABASE_URL=postgresql+asyncpg://microhabit:microhabit@127.0.0.1:5432/microhabit

# CREATE_TABLES_ON_STARTUP=true

# Auth — JWT signing key (required in production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=change-me-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenAI — required for AI-assisted habit suggestions (v2.0).
# When absent or empty, the endpoint falls back to the keyword suggestion engine.
# OPENAI_API_KEY=sk-...

# Google Calendar — read-only availability integration (v3.0).
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials.
# Add redirect URI: http://localhost:8000/calendar/auth/callback (dev) or your production URL.
# All three vars must be present to enable calendar features; leave blank to disable gracefully.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/auth/callback
# FRONTEND_URL=http://localhost:3000

# Fernet key for encrypting stored Google OAuth tokens in the database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when Google Calendar is enabled. Rotating this key invalidates all stored connections.
# CALENDAR_ENCRYPTION_KEY=
